<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- SMS capture for auto-import (Tanda 2) -->
    <uses-permission android:name="android.permission.RECEIVE_SMS"/>
    <uses-permission android:name="android.permission.READ_SMS"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- Voice input for AI dictation (voice-input-and-ai-tools) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Biometric authentication -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    <uses-permission android:name="android.permission.USE_FINGERPRINT"/>

    <!-- Background service for auto-import (Tanda 4) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- Robust permissions for listener liveness (Tanda 3: Permisos Robustos) -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:label="Wallex"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        <!-- Background Service for auto-import (Tanda 4)
             android:process=":capture" isolates the second FlutterEngine into
             a dedicated OS process so loading libflutter.so a second time
             (~295 ms on arm64) does NOT block the main UI thread during cold
             start. Main process renders the first frame immediately; the
             capture process spins up in parallel and owns the foreground
             notification + SMS/API sources. Drift DB uses WAL (multi-process
             safe readers) and notification capture is pinned to the main
             isolate via applySettings(channels: {sms, api}) in the background
             onStart, so no cross-process EventChannel coupling. -->
        <service
            android:name="id.flutter.flutter_background_service.BackgroundService"
            android:process=":capture"
            android:foregroundServiceType="specialUse"
            android:exported="false"
            tools:replace="android:exported,android:process,android:foregroundServiceType">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="financial_transaction_monitoring"/>
        </service>

        <!-- Notification Listener for auto-import (Tanda 3A) -->
        <service
            android:label="notifications"
            android:name="notification.listener.service.NotificationListener"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            tools:replace="android:exported">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService"/>
            </intent-filter>
        </service>

        <!--
          Explicit boot receiver to resurrect the capture foreground service
          after a reboot. flutter_background_service's `autoStartOnBoot: true`
          registers its own receiver inside the plugin module; on MIUI /
          HyperOS that receiver is frequently disabled by OEM autostart
          policies. Having our OWN receiver under the app's package
          maximizes the chance that at least one survives OEM pruning.
          Tanda listener-hardening / overnight-death fix.
        -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Battery optimization settings (Tanda 3: Permisos Robustos) -->
        <intent>
            <action android:name="android.settings.IGNORE_BATTERY_OPTIMIZATION_SETTINGS"/>
        </intent>
        <intent>
            <action android:name="android.settings.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
        </intent>
        <!-- Android 11+ package visibility: speech_to_text uses this to
             enumerate installed RecognitionService implementations. Without
             this intent filter, availableLocales() returns an empty list on
             API 30+ and `listen()` silently fails. -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
    </queries>
</manifest>
